// 主题色板：通过 CSS 变量实现深色模式，运行时切换无需重建
// 模式由 _config.color_mode 控制（light | dark | auto | time），详见 README
:root {
  --c-bg: #fcfcfb;            // 页面/墙覆盖底色
  --c-bg-soft: #eff2f3;       // 次级背景
  --c-bg-muted: #f5f5f5;      // 静音背景（卡片底/分页等）
  --c-bg-card: #ffffff;       // 卡片背景
  --c-bg-overlay: rgba(255, 255, 255, 0.25);  // 导航毛玻璃底
  --c-bg-overlay-strong: rgba(255, 255, 255, 0.9);  // 移动端导航底
  --c-wall-overlay: rgba(255, 255, 255, 0.95);
  --c-wall-overlay-hover: rgba(255, 255, 255, 0.8);
  --c-text: #555;             // 正文
  --c-text-heading: #222;     // 标题
  --c-text-soft: #666;
  --c-text-muted: #888;
  --c-border: #eee;
  --c-border-strong: #ddd;
  --c-link: #555;
  --c-link-hover: #222;
  --c-shadow: rgba(0, 0, 0, 0.04);
  --c-paginator: #333;
  --c-nav-btn: #333;
  --c-footer-bg: #000;
  --c-footer-text: #aaa;
  --c-footer-text-hover: #888;
  --c-accent: #2c5fa5;
  --c-accent-hover: #2472e7;
  --c-accent-soft: #568dc4;
  --c-radio-track: #ccc;
  --c-radio-thumb: #fafafa;
  --c-on-accent: #fff;
  --c-mask: rgba(200, 200, 200, 0.8);
  --c-code-bg: #f7f7f7;
  --c-code-text: #24292e;
  --c-link-search: #143c74;        // 搜索结果链接
  --c-gutter: #bbb;                // 代码块行号
  --c-post-info: #bbb;             // 文章元信息（日期等）
  --c-highlight-bg: yellow;        // 搜索关键词高亮背景
  --c-highlight-text: #000;        // 搜索关键词高亮文字
}

[data-theme="dark"] {
  --c-bg: #1a1a1a;
  --c-bg-soft: #242424;
  --c-bg-muted: #2a2a2a;
  --c-bg-card: #2a2a2a;
  --c-bg-overlay: rgba(26, 26, 26, 0.35);
  --c-bg-overlay-strong: rgba(20, 20, 20, 0.92);
  --c-wall-overlay: rgba(26, 26, 26, 0.92);
  --c-wall-overlay-hover: rgba(26, 26, 26, 0.75);
  --c-text: #c4c4c4;
  --c-text-heading: #e8e8e8;
  --c-text-soft: #aeaeae;
  --c-text-muted: #888;
  --c-border: #3a3a3a;
  --c-border-strong: #4a4a4a;
  --c-link: #c4c4c4;
  --c-link-hover: #ffffff;
  --c-shadow: rgba(0, 0, 0, 0.4);
  --c-paginator: #c4c4c4;
  --c-nav-btn: #ddd;
  --c-footer-bg: #0d0d0d;
  --c-footer-text: #9a9a9a;
  --c-footer-text-hover: #c4c4c4;
  --c-accent: #6ba4d8;
  --c-accent-hover: #8bb8e8;
  --c-accent-soft: #6ba4d8;
  --c-radio-track: #4a4a4a;
  --c-radio-thumb: #2a2a2a;
  --c-on-accent: #fff;
  --c-mask: rgba(0, 0, 0, 0.7);
  --c-code-bg: #1e1e1e;
  --c-code-text: #e8e8e8;
  --c-link-search: #79c0ff;         // 深色模式搜索链接改亮蓝
  --c-gutter: #666;                 // 行号加暗
  --c-post-info: #888;              // 元信息暗化
  --c-highlight-bg: rgba(255, 217, 0, 0.35);  // 高亮背景降低亮度避免刺眼
  --c-highlight-text: #e8e8e8;      // 高亮文字改浅
}

/* prefers-reduced-motion：为偏好减少动画的用户全局禁用动画 */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}
