@import '../_variables';
@import '../_mixins';

if (hexo-config('algolia.enable')) {
  @import './algolia-search';
} else if (hexo-config('search.enable')) {
  @import './search';
}

.nav {
  position: relative;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 50px;
  height: 90px;
  font-weight: bold;
}

.head--sticky {
  position: fixed;
  left: 0;
  right: 0;
  background: var(--c-bg-overlay);
  backdrop-filter: blur(15px) saturate(0.3);
  top: 0;
  z-index: 1;
}

#navBtn {
  top: -100px;
  position: fixed;
  opacity: 0;
  display: block;
  height: 0;
  width: 0;
}

.nav-btn {
  display: none;
}

.nav-logo {
  height: 60px;
  width: 60px;
}

.nav-menu {
  display: flex;
  align-items: center;
}

// 深色模式切换按钮：显示当前主题对应的图标
.theme-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  margin: 0 12px;
  padding: 0;
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--c-text);
  border-radius: 50%;
  transition: background 200ms ease, color 200ms ease;

  &:hover {
    background: var(--c-bg-muted);
  }

  &__icon {
    display: none;
    line-height: 0;
  }
}

// 当前为深色时显示太阳（点击切回浅色），浅色时显示月亮
[data-theme="dark"] .theme-toggle__icon--sun {
  display: inline-flex;
}

[data-theme="light"] .theme-toggle__icon--moon {
  display: inline-flex;
}

.nav-menu-item {
  letter-spacing: 0.1em;
  text-decoration: none;
  margin: 0 20px;
}

.nav-menu-item:hover {
  cursor: pointer;
}

@media screen and (max-width: 1023px) {
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: var(--c-bg-overlay-strong);
    z-index: 99;
    justify-content: center;
  }

  .head--sticky {
    position: relative;
    backdrop-filter: none;
    background: none;
  }

  .nav-menu {
    position: fixed;
    top: 60px;
    bottom: 0;
    height: 0;
    transition: height 200ms ease-out;
    left: 0;
    right: 0;
    z-index: 4;
    background: var(--c-bg-overlay-strong);
    overflow: hidden;
    flex-direction: column;
    align-items: flex-start;
    padding-left: 40px;
  }

  .nav-menu-item {
    margin: 20px 0;
  }

  .nav-logo {
    height: 40px;
    width: 40px;

    img {
      height: 40px;
      width: 40px;
    }
  }

  .nav-btn {
    display: block;
    position: absolute;
    left: 0;
    padding: 10px 20px;
    height: 40px;
    width: 40px;

    &::before, &::after {
      transition: transform 200ms ease-out;
      content: '';
      background: var(--c-nav-btn);
      width: 30px;
      height: 2px;
      border-radius: 1px;
      position: absolute;
    }

    &::before {
      top: 25px;
    }

    &::after {
      bottom: 25px;
    }
  }

  #navBtn:checked ~ .nav-right .nav-menu {
    height: 100%;
  }

  #navBtn:checked ~ .nav-btn {
    &::before {
      transform: translateY(4px) rotateZ(45deg);
    }

    &::after {
      transform: translateY(-4px) rotateZ(-45deg);
    }
  }
}

.nav-right {
  display: flex;
  align-items: center;
}
