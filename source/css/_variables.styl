// 颜色通过 CSS 变量映射到 _theme.styl，支持运行时深色模式切换
$white-blue-lightest = var(--c-bg);
$white-blue = var(--c-bg-soft);
$whitesmoke-light = var(--c-bg-muted);
$whitesmoke = var(--c-bg-muted);
$gainsboro = var(--c-border);
$grey-lighter = var(--c-border-strong);
$grey-light = #ccc;
$grey = var(--c-gutter);
$black = #000;
$black-light = var(--c-text);
$black-lighter = var(--c-text-soft);
$black-extra-lighter = var(--c-text-muted);
$black-dim = var(--c-paginator);
$black-deep = var(--c-text-heading);
$blue-link = var(--c-link-search);
$blue-link-light = var(--c-link-search);
$text-bold-background = var(--c-highlight-bg);
$text-bold-color = var(--c-highlight-text);
$text-color = var(--c-text);
$link-color = var(--c-link);
$link-hover-color = var(--c-link-hover);
$font-size-base = 18px;
$font-size-smallest = 0.75em;
$font-size-smaller = 0.8125em;
$font-size-small = 0.875em;
$font-size-medium = 1em;
$font-size-large = 1.125em;
$font-size-larger = 1.25em;
$font-size-largest = 1.5em;
$font-size-title = 2.5em;
$font-family-base = sans-serif;
$font-family-serif = sourceHanSerif;
$max-width = 1200px;
$content-width = 900px;
