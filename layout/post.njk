{% extends "_partials/layout.njk" %}
{% block link %}
  <link rel="stylesheet" type="text/css" href="{{ url_for("/css/post.css") }}"/>
{% endblock link %}
{% block body %}
  <article class="post-content">
    <div class="post-inner{{ '--toc' if page.toc else '' }}">
      <div class="post-content__head">
        <div class="post-title">{{ page.title or "未命名" }}</div>
        <div class="post-info">
          {{ partial("_partials/macros/tags.njk", {tags: page.tags}) }}
          <span class="post-date">{{ date(page.date) }}</span>
        </div>
      </div>
      {% if page.toc %}
        <aside class="toc-outer">
          <div class="toc-title">目录</div>
          {{ toc(page.content, {list_number: false, max_depth: 4, class: 'post-toc'}) }}
          <a href="#" class="toc-top">回到顶部</a>
        </aside>
      {% endif %}
      <div class="post-content__body">
        {% if page.photos %}
          <div class="post-gallery">
            {% for photo in page.photos %}<img alt="cover" loading="lazy" decoding="async" src="{{ url_for(photo) }}"/>{% endfor %}
          </div>
        {% endif %}
        {{ page.content }}
      </div>
    </div>
    {% if theme.mermaid.enable %}
      <script src='{{ theme.cdn or 'https://cdn.jsdelivr.net/npm' }}/mermaid@{{ theme.mermaid.version }}/dist/mermaid.min.js'></script>
      <script>
        if (window.mermaid) {
          mermaid.initialize({{ theme.mermaid.options | dump }});
          // 10.x+ 用 mermaid.run()，9.x 用 mermaid.init()，做兼容 fallback
          if (typeof mermaid.run === 'function') {
            mermaid.run();
          } else if (typeof mermaid.init === 'function') {
            mermaid.init();
          }
        }
      </script>
    {% endif %}
  </article>
  <div class="post__foot">
    {% if theme.reward.enable %}
      {% include "_partials/components/reward.njk" %}
    {% endif %}
    {% include "_partials/components/post-nav.njk" %}
    {% if theme.related_post.enable %}
      {% include "_partials/components/related-post.njk" %}
    {% endif %}
  </div>
{% endblock body %}
{% block script %}
  {% if page.toc %}<script defer src="{{ url_for('js/toc.js') }}"></script>{% endif %}
{% endblock script %}
